<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Obsera Live Network | Restaurant Directory</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Space+Grotesk:wght@700&display=swap" rel="stylesheet">
    
    <script src="clients.js"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        'sans': ['Inter', 'sans-serif'],
                        'display': ['Space Grotesk', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    <style>
        body { background-color: #0f172a; color: white; }
        
        .glass-panel {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .fade-in { animation: fadeIn 0.5s ease-out forwards; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="min-h-screen flex flex-col bg-[#0f172a] relative overflow-x-hidden antialiased">

    <div class="fixed inset-0 w-full h-full pointer-events-none z-0">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-sky-500/10 rounded-full blur-[120px]"></div>
    </div>

    <header class="glass-panel sticky top-0 z-50 border-b border-white/10">
        <div class="container mx-auto px-6 py-4 flex justify-between items-center">
            <a href="index.html" class="flex items-center gap-3 group">
                <img src="https://raw.githubusercontent.com/Dax4477/obsera-assets/main/Gemini_Generated_Image_jejmw3jejmw3jejm.png" alt="Obsera Logo" class="h-8 transition-transform group-hover:scale-105">
                <span class="font-display font-bold text-xl tracking-wide text-white">OBSERA</span>
            </a>
            <div class="flex items-center gap-2">
                <span class="bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-xs uppercase font-bold px-3 py-1.5 rounded-full flex items-center gap-2 shadow-[0_0_10px_rgba(16,185,129,0.2)]">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span> Network Live
                </span>
            </div>
        </div>
    </header>

    <main class="flex-grow container mx-auto px-6 py-12 relative z-10">
        
        <div class="text-center mb-12 fade-in">
            <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">Discover Local Flavors</h1>
            <p class="text-slate-400 text-lg max-w-2xl mx-auto mb-8">Browse live interactive menus from our partnered restaurants across the city.</p>
            
            <div class="max-w-xl mx-auto relative">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </div>
                <input type="text" id="searchInput" placeholder="Search for a restaurant..." 
                    class="w-full bg-slate-800/80 border border-slate-600 text-white rounded-xl pl-11 pr-4 py-4 focus:outline-none focus:border-sky-400 focus:ring-1 focus:ring-sky-400 transition-all shadow-inner">
            </div>
        </div>

        <div id="restaurant-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 fade-in" style="animation-delay: 0.1s;">
            </div>

    </main>

    <footer class="border-t border-white/10 py-8 text-center text-slate-500 text-sm relative z-10 bg-slate-900/50">
        &copy; 2026 Obsera Solutions. All Rights Reserved.
    </footer>

    <script>
        let currentClientsDataText = "";

        // Explicitly map the original data to the window so mobile browsers don't block the overwrite
        if (typeof OBSERA_CLIENTS !== 'undefined') {
            window.OBSERA_CLIENTS = OBSERA_CLIENTS;
        }

        if (typeof window.OBSERA_CLIENTS === 'undefined') {
            document.getElementById('restaurant-grid').innerHTML = `
                <div class="col-span-full text-center py-10">
                    <p class="text-red-400 font-bold text-xl">System Error: Could not connect to the Obsera Network (clients.js missing).</p>
                </div>
            `;
        } else {
            const gridContainer = document.getElementById('restaurant-grid');
            const searchInput = document.getElementById('searchInput');

            // --- 1. RENDER FUNCTION ---
            function renderGrid(filterText = '') {
                let html = ''; 
                let matchCount = 0;
                
                const activeData = window.OBSERA_CLIENTS;
                const clientIds = Object.keys(activeData);

                // Build the active client cards
                clientIds.forEach(id => {
                    const client = activeData[id];
                    
                    if (client.name.toLowerCase().includes(filterText.toLowerCase())) {
                        matchCount++;
                        
                        const defaultBg = 'https://images.unsplash.com/photo-1555396273-367ea4eb4db5?auto=format&fit=crop&q=80&w=800';
                        const mapHtml = client.mapLink ? `
                            <a href="${client.mapLink}" target="_blank" class="flex items-center justify-center gap-1 bg-slate-700 hover:bg-slate-600 text-white px-4 py-2 rounded-lg transition-colors text-sm font-semibold border border-slate-600">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            </a>
                        ` : '';

                        html += `
                            <div class="bg-slate-800/80 border border-slate-700 rounded-2xl overflow-hidden hover:border-sky-400/50 hover:shadow-[0_0_20px_rgba(56,189,248,0.15)] transition-all duration-300 group flex flex-col h-full min-h-[350px]">
                                
                               
                                
                                <a href="mobile?client=${id}" target="_blank" class="block h-32 bg-slate-700 relative overflow-hidden shrink-0 cursor-pointer">
                                    <img src="${defaultBg}" class="w-full h-full object-cover opacity-40 group-hover:opacity-60 transition-opacity duration-500 group-hover:scale-105 transform">
                                    <div class="absolute inset-0 bg-gradient-to-t from-slate-800/80 to-transparent"></div>
                                    <div class="absolute bottom-3 left-4">
                                        <span class="bg-black/50 backdrop-blur-sm border border-white/10 text-white text-[10px] uppercase font-bold tracking-widest px-2 py-1 rounded shadow-lg">
                                            ${client.tag || client.hours + 'h Active'}
                                        </span>
                                    </div>
                                    
                                    <div class="hidden absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                        <span class="bg-sky-500 text-slate-900 text-[10px] font-bold uppercase tracking-widest px-3 py-1.5 rounded-full shadow-[0_0_15px_rgba(56,189,248,0.5)]">
                                            Open Link
                                        </span>
                                    </div>
                                </a>

                                <div class="p-5 flex flex-col flex-grow">
                                    <h2 class="text-xl font-bold text-white mb-1 group-hover:text-sky-400 transition-colors">${client.name}</h2>
                                    <p class="text-slate-400 text-sm mb-6 flex-grow">Tap to view live digital menu and ongoing offers.</p>
                                    
                                    <div class="flex gap-3 mt-auto">
                                        <a href="mobile?client=${id}" class="flex-grow bg-sky-500 hover:bg-sky-400 text-slate-900 font-bold py-2 rounded-lg text-center text-sm transition-colors shadow-md flex items-center justify-center gap-2">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                                            View Live Menu
                                        </a>
                                        ${mapHtml}
                                    </div>
                                </div>
                            </div>
                        `;
                    }
                });

                // Check for matches
                if (matchCount === 0) {
                    html = `
                        <div class="col-span-full text-center py-12">
                            <svg class="w-12 h-12 text-slate-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            <p class="text-slate-400 text-lg">No restaurants found matching "${filterText}"</p>
                        </div>
                    `;
                } else if (filterText === '') {
                    // Only show "Coming Soon" padding if the user is NOT actively searching
                    const minimumCards = 3;
                    const paddingNeeded = minimumCards - matchCount;
                    
                    if (paddingNeeded > 0) {
                        for (let i = 0; i < paddingNeeded; i++) {
                            html += `
                                <div class="rounded-2xl bg-slate-800/30 border border-slate-700 h-full min-h-[350px] flex flex-col items-center justify-center text-center p-6 border-dashed opacity-50">
                                    <span class="text-slate-500 font-display font-bold text-2xl mb-2">Location Setup</span>
                                    <span class="text-xs px-2 py-1 font-bold uppercase tracking-widest rounded bg-white/5 text-slate-400">Coming Soon</span>
                                </div>
                            `;
                        }
                    }
                }

                // Push HTML to the DOM exactly once
                gridContainer.innerHTML = html;
            }

            searchInput.addEventListener('input', (e) => {
                renderGrid(e.target.value);
            });

            // --- 2. SILENT BACKGROUND POLLER ---
            async function checkForNewClients() {
                try {
                    const response = await fetch('clients.js?t=' + Date.now(), { cache: 'no-store' });
                    const newText = await response.text();
                    
                    if (currentClientsDataText === "") {
                        currentClientsDataText = newText;
                        return;
                    }

                    if (newText !== currentClientsDataText) {
                        currentClientsDataText = newText;
                        
                        let safeCode = newText.replace(/(const|let|var)\s+OBSERA_CLIENTS/g, "window.OBSERA_CLIENTS");
                        eval(safeCode);
                        
                        renderGrid(searchInput.value);
                    }
                } catch (err) {
                    console.error("Silent update failed:", err);
                }
            }

            // Mobile Battery Saver Bypass
            document.addEventListener("visibilitychange", () => {
                if (document.visibilityState === "visible") {
                    checkForNewClients();
                }
            });

            // Render it immediately on load
            renderGrid();

            // Then check for changes to clients.js every 5 seconds silently
            setInterval(checkForNewClients, 5000);
        }
    </script>
</body>
</html>