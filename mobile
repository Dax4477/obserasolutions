<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" /> 
    
    <title>Obsera Mobile Menu</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.3.0/papaparse.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&family=Roboto:wght@400;500&display=swap" rel="stylesheet">

    <script src="clients.js"></script>

    <style>
        .font-heading { font-family: 'Oswald', sans-serif; }
        .font-body { font-family: 'Roboto', sans-serif; }
        .fade-in { animation: fadeIn 0.4s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* Smooth Scrolling Text for Mobile (Speed is now controlled by JS) */
        .smooth-scroll {
            display: inline-block; 
            white-space: nowrap; 
            will-change: transform;
            animation-name: scroll-left;
            animation-timing-function: linear;
            animation-iteration-count: infinite;
        }
        @keyframes scroll-left {
            from { transform: translateX(100vw); } 
            to { transform: translateX(-100%); } 
        }
    </style>
</head>

<body class="bg-gray-900 text-white min-h-screen flex flex-col font-body antialiased">

    <header class="bg-blue-800 px-4 py-3 shadow-lg z-50 sticky top-0 w-full flex justify-between items-center border-b border-blue-900">        
        <div class="flex flex-col">
            <h1 id="restaurant-name-display" class="text-xl font-heading font-bold uppercase tracking-wide leading-none text-white shadow-sm">LOADING...</h1>
            <p class="text-blue-200 text-[10px] font-bold tracking-wider mt-1 uppercase">Powered by Obsera</p>
        </div>
        <div id="clock" class="text-xs font-mono font-bold text-white bg-black/30 border border-white/10 px-2 py-1 rounded">00:00</div>
    </header>

    <main class="flex-grow w-full pb-20 relative">
        <div id="menu-container" class="w-full px-4 pt-4 pb-12">
            <div class="flex flex-col items-center justify-center h-[50vh] space-y-4">
                <div class="animate-spin rounded-full h-10 w-10 border-t-2 border-b-2 border-blue-500"></div>
                <p class="text-gray-400 text-sm uppercase tracking-widest font-bold">CONNECTING TO OBSERA NETWORK</p>
            </div>
        </div>
    </main>

    <footer class="fixed bottom-0 left-0 w-full bg-black z-40 border-t-2 border-blue-800 h-10 flex items-center overflow-hidden">
        <div id="ticker-text" class="smooth-scroll text-lg text-yellow-400 font-bold tracking-wider w-max min-w-full shrink-0">
            ★ CONTACT OBSERA SOLUTIONS ★ WHATSAPP- +91 9562551376
        </div>
    </footer>

<script>
    // --- 1. INITIALIZE CLIENT DATA ---
    const urlParams = new URLSearchParams(window.location.search);
    let clientId = urlParams.get('client'); 
    
    if (clientId) { 
        clientId = clientId.toLowerCase().trim(); 
        
        // SILENT ANALYTICS PING
        fetch(`https://obserasolutions.site/track.php?client=${clientId}`)
            .catch(e => console.log("Analytics ping failed"));
    }

    const clientData = OBSERA_CLIENTS[clientId];

    if (!clientData) {
        document.body.innerHTML = `
            <div style="display:flex; height:100vh; background:#0f172a; align-items:center; justify-content:center; flex-direction:column; text-align:center; padding:20px;">
                <h1 style="color:#ef4444; font-size:1.5rem; font-family:sans-serif; font-weight:bold; margin-bottom:1rem;">LOCATION NOT FOUND</h1>
                <p style="color:#94a3b8; font-size:1rem; font-family:sans-serif;">Please scan a valid QR code.</p>
            </div>`;
        throw new Error("Client ID does not exist in clients.js");
    }

    // Update the UI
    document.getElementById('restaurant-name-display').innerText = clientData.name;

    const MENU_SHEET_URL = `https://docs.google.com/spreadsheets/d/${clientData.menuSheetId}/export?format=csv&gid=0`;
    const AD_SHEET_URL = `https://docs.google.com/spreadsheets/d/${clientData.adSheetId}/export?format=csv&gid=0`;

    const CHECK_INTERVAL = 30000;    
    let currentMenuDataHash = ""; 

    // --- 2. FETCH DATA ---
    function fetchMenuData() {
        const uniqueMenuUrl = MENU_SHEET_URL + '&t=' + Date.now();
        const uniqueAdUrl = AD_SHEET_URL + '&t=' + Date.now();

        Promise.all([
            fetch(uniqueMenuUrl, { cache: "no-store" }).then(r => r.ok ? r.text() : null).catch(() => null),
            fetch(uniqueAdUrl, { cache: "no-store" }).then(r => r.ok ? r.text() : null).catch(() => null)
        ])
        .then(([menuCsv, adCsv]) => {
            let combinedData = { menuRows: [], adRows: [] };

            if (menuCsv) {
                Papa.parse(menuCsv, { 
                    header: true, 
                    skipEmptyLines: true, 
                    complete: res => combinedData.menuRows = res.data 
                });
            }
            if (adCsv) {
                Papa.parse(adCsv, { 
                    header: true, 
                    skipEmptyLines: true, 
                    complete: res => combinedData.adRows = res.data 
                });
            }

            setTimeout(() => { processData(combinedData); }, 200);
        })
        .catch(e => console.error("Error fetching sheets:", e));
    }

    function processData(combinedData) {
        const newHash = JSON.stringify(combinedData);
        if (newHash === currentMenuDataHash) return;
        currentMenuDataHash = newHash;

        let menuGroups = {};
        let adList = [];
        let tickerMessage = "★ FOR ADVERTISING HERE ★ CONTACT OBSERA SOLUTIONS ★ WHATSAPP- +91 9562551376";

        combinedData.menuRows.forEach(row => {
            let safeRow = {};
            Object.keys(row).forEach(k => safeRow[k.toLowerCase().trim()] = row[k]);

            let cat = safeRow.category ? safeRow.category.trim().toUpperCase() : "OUR MENU";
            
            if (safeRow.name && cat !== "ADVERTISEMENT") {
                if (!menuGroups[cat]) menuGroups[cat] = [];
                menuGroups[cat].push({
                    name: safeRow.name,
                    price: safeRow.price,
                    desc: safeRow.desc || safeRow.description || "",
                    image: safeRow.image
                });
            }
        });

        combinedData.adRows.forEach(row => {
            let safeRow = {};
            Object.keys(row).forEach(k => safeRow[k.toLowerCase().trim()] = row[k]);
            
            if ((safeRow.name && safeRow.name.toUpperCase() === "TICKER") || 
                (safeRow.category && safeRow.category.toUpperCase() === "TICKER")) {
                let msg = safeRow.desc || safeRow.description || "";
                if (msg.length > 0) tickerMessage = msg;
                return;
            }

            let cat = safeRow.category ? safeRow.category.trim().toUpperCase() : "";
            
            if (cat === "ADVERTISEMENT" || cat === "AD") {
                if (safeRow.image) {
                    const isVideo = safeRow.image.match(/\.(mp4|webm|ogg)$/i);
                    let rawLink = safeRow.link || "";
                    let finalLink = rawLink.trim();
                    if (finalLink !== "" && !finalLink.startsWith('http')) {
                        finalLink = 'https://' + finalLink;
                    }

                    let pos = parseInt(safeRow.position);
                    adList.push({
                        type: isVideo ? 'video' : 'image',
                        image: safeRow.image,
                        link: finalLink,
                        position: isNaN(pos) ? null : pos
                    });
                }
            }
        });

        const tickerElement = document.getElementById('ticker-text');
        if (tickerElement) {
            tickerElement.innerText = tickerMessage;
            setTimeout(adjustTickerSpeed, 300);
        }

        renderMobileView(menuGroups, adList);
    }

    // --- 3. MOBILE RENDER ENGINE ---
    function renderMobileView(menuGroups, adList) {
        const container = document.getElementById('menu-container');
        let html = '';
        const categories = Object.keys(menuGroups);

        const createAdBlock = (ad) => {
            const hasLink = ad.link && ad.link.trim() !== "";
            
            const trackClick = hasLink ? `onclick="fetch('https://obserasolutions.site/track.php?client=${clientId}&ad_click=${encodeURIComponent(ad.link)}');"` : "";

            const wrapperStart = hasLink ? `<a href="${ad.link}" target="_blank" ${trackClick} class="block cursor-pointer relative group">` : `<div class="block relative">`;
            const wrapperEnd = hasLink ? `</a>` : `</div>`;
            
            const clickHint = hasLink ? `
                <div class="absolute bottom-3 right-3 bg-blue-500 text-white text-[10px] font-bold px-3 py-1.5 rounded-full flex items-center gap-1 shadow-lg z-20">
                    Tap to Visit 
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                </div>` : ``;

            const mediaContent = ad.type === 'video' 
                ? `<video src="${ad.image}" class="w-full h-auto object-contain max-h-[250px]" autoplay loop muted playsinline></video>`
                : `<img src="${ad.image}" class="w-full h-auto object-contain max-h-[250px]" loading="lazy">`;

            return `
                <div class="mb-8 rounded-xl overflow-hidden shadow-lg border border-gray-700 fade-in bg-black relative">
                    ${wrapperStart}
                        <span class="absolute top-3 left-3 bg-black/80 backdrop-blur-sm border border-white/10 text-white text-[9px] font-bold uppercase tracking-widest px-2 py-1 rounded z-20">Sponsored</span>
                        ${clickHint}
                        ${mediaContent}
                    ${wrapperEnd}
                </div>
            `;
        };

        let currentCategoryNumber = 1;
        categories.forEach((categoryName) => {
            const items = menuGroups[categoryName];
            html += `
                <div class="sticky top-[52px] z-30 bg-gray-900/95 backdrop-blur-md pt-4 pb-2 mb-3 border-b-2 border-gray-700">
                    <h2 class="text-xl font-heading font-bold text-yellow-400 tracking-wide">${categoryName}</h2>
                </div>
                <div class="grid grid-cols-1 gap-3 mb-8">
            `;

            items.forEach(item => {
                const fallbackImage = 'https://placehold.co/300x300/1f2937/FFF?text=No+Image';
                html += `
                    <div class="flex bg-gray-800 rounded-xl overflow-hidden shadow-md border border-gray-700/50 min-h-[100px] fade-in relative">
                        <div class="w-1/3 bg-gray-700 relative shrink-0">
                            <img src="${item.image}" class="h-full w-full object-cover absolute inset-0" onerror="this.src='${fallbackImage}'" loading="lazy">
                        </div>
                        <div class="w-2/3 p-3 flex flex-col justify-center">
                            <div class="flex justify-between items-start mb-1 gap-2">
                                <h3 class="text-base font-bold text-white font-heading leading-tight">${item.name}</h3>
                                <span class="bg-red-600 text-white px-2 py-0.5 rounded text-xs font-bold whitespace-nowrap shadow-sm">${item.price}</span>
                            </div>
                            <p class="text-gray-400 text-xs leading-snug line-clamp-2 mt-1">${item.desc}</p>
                        </div>
                    </div>
                `;
            });
            html += `</div>`;

            const adsForThisPosition = adList.filter(ad => ad.position === currentCategoryNumber);
            adsForThisPosition.forEach(ad => { html += createAdBlock(ad); });
            currentCategoryNumber++;
        });

        // Remaining Ads
        const unplacedAds = adList.filter(ad => !ad.position || ad.position > categories.length);
        unplacedAds.forEach(ad => { html += createAdBlock(ad); });

        // 🛠️ NEW: LIVE JUKEBOX VOTE BUTTON ADDED HERE
        html += `
            <div class="mt-8 mb-4 fade-in">
                <a href="https://obserasolutions.site/mobile_vote" class="w-full flex items-center justify-center gap-3 bg-gradient-to-r from-sky-500 to-blue-600 hover:from-sky-400 hover:to-blue-500 text-white font-heading font-bold text-xl py-4 rounded-xl shadow-[0_0_20px_rgba(56,189,248,0.3)] active:scale-95 transition-all border border-sky-400/30">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path></svg>
                    VOTE FOR LIVE JUKEBOX
                </a>
            </div>
        `;

        container.innerHTML = html;
    }

    function updateClock() {
        document.getElementById('clock').innerText = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }

    function adjustTickerSpeed() {
        const ticker = document.getElementById('ticker-text');
        if (!ticker) return;
        const textWidth = ticker.offsetWidth;
        const screenWidth = window.innerWidth;
        const duration = (screenWidth + textWidth) / 75; 
        ticker.style.animationDuration = `${duration}s`;
    }

    window.addEventListener('resize', adjustTickerSpeed);
    fetchMenuData(); 
    setInterval(updateClock, 1000); 
    setInterval(fetchMenuData, CHECK_INTERVAL); 
    updateClock();
</script>
</body>
</html>